#!/usr/bin/env bash
set -Eeuo pipefail

repo_config="${SAGGEO_GHOSTTY_CONFIG:-}"
config_dir="${HOME}/.config/ghostty"
config_file="${config_dir}/config"
nerd_font_url="${SAGGEO_NERD_FONT_URL:-https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip}"

log() {
  printf '[saggeo-terminal] %s\n' "$*"
}

fonte_nerd_instalada() {
  command -v fc-match >/dev/null 2>&1 \
    && fc-match -f '%{family}\n' 'JetBrainsMono Nerd Font' 2>/dev/null \
      | grep -qi 'JetBrainsMono Nerd Font'
}

instalar_nerd_font() {
  local font_dir zip_file

  if fonte_nerd_instalada; then
    log "JetBrainsMono Nerd Font ja instalada."
    return
  fi

  if ! command -v curl >/dev/null 2>&1 || ! command -v unzip >/dev/null 2>&1 || ! command -v fc-cache >/dev/null 2>&1; then
    echo "Nao encontrei curl/unzip/fontconfig para instalar a Nerd Font." >&2
    exit 1
  fi

  log "Instalando JetBrainsMono Nerd Font para icones do terminal."
  font_dir="${HOME}/.local/share/fonts/JetBrainsMonoNerdFont"
  zip_file="$(mktemp)"

  mkdir -p "${font_dir}"
  curl -fsSL -o "${zip_file}" "${nerd_font_url}"
  unzip -o -q "${zip_file}" -d "${font_dir}"
  rm -f "${zip_file}"
  fc-cache -f "${HOME}/.local/share/fonts" >/dev/null
}

escrever_config_padrao() {
  cat > "${config_file}" <<'EOF'
font-family = JetBrainsMono Nerd Font
font-size = 14
window-padding-x = 12
window-padding-y = 12
copy-on-select = true
keybind = global:opt+space=toggle_quick_terminal
quick-terminal-autohide = false
quick-terminal-position = top

# Tema "Clear Dark" extraido do perfil do Terminal.app.
background = #212734
foreground = #e6e6e6
selection-background = #334e5e
palette = 0=#35424c
palette = 1=#b45648
palette = 2=#6caa71
palette = 3=#c4ac62
palette = 4=#6d96b4
palette = 5=#bd7bcd
palette = 6=#7ccbcd
palette = 7=#dee5eb
palette = 8=#465c6d
palette = 9=#df6c5a
palette = 10=#79be7e
palette = 11=#e5c872
palette = 12=#67b5ed
palette = 13=#d389e5
palette = 14=#84dde0
palette = 15=#e5eff5

background-opacity = 0.95
background-blur = 20
EOF
}

aplicar_config_ghostty() {
  mkdir -p "${config_dir}"

  if [[ -n "${repo_config}" && -f "${repo_config}" ]]; then
    install -m 0644 "${repo_config}" "${config_file}"
  else
    escrever_config_padrao
  fi

  log "Config Ghostty aplicada em ${config_file}."
}

configurar_alternativa_terminal() {
  local ghostty_bin

  if command -v ghostty >/dev/null 2>&1; then
    ghostty_bin="$(command -v ghostty)"
  elif [[ -x /snap/bin/ghostty ]]; then
    ghostty_bin="/snap/bin/ghostty"
  else
    log "Ghostty ainda nao esta instalado; apenas a config foi preparada."
    return
  fi

  if command -v update-alternatives >/dev/null 2>&1 && command -v sudo >/dev/null 2>&1 && sudo -n true >/dev/null 2>&1; then
    sudo update-alternatives --install /usr/bin/x-terminal-emulator x-terminal-emulator "${ghostty_bin}" 90 >/dev/null 2>&1 || true
    sudo update-alternatives --set x-terminal-emulator "${ghostty_bin}" >/dev/null 2>&1 || true
    log "Ghostty definido como x-terminal-emulator."
  fi
}

main() {
  instalar_nerd_font
  aplicar_config_ghostty
  configurar_alternativa_terminal
  log "Abra o Ghostty para usar a configuracao Clear Dark."
}

main "$@"
